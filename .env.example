# WorkMemory Agent 环境变量示例
# 复制为 .env 后生效：copy .env.example .env
# 后端只读取 .env；本文件只作为说明，不会被运行时自动加载。
# 不要把真实 API Key 提交到代码仓库。

# -----------------------------
# 应用基础信息
# -----------------------------
# 应用名称，会在健康检查和设置页中展示。
APP_NAME=WorkMemory Agent

# 运行环境标识。常用值：development、test、production。
APP_ENV=development

# 应用版本号，仅用于状态展示。
APP_VERSION=0.1.0

# 应用默认时区。当前主要用于状态展示和后续时间处理。
APP_TIMEZONE=Asia/Shanghai

# -----------------------------
# 后端服务
# -----------------------------
# FastAPI 监听地址。Windows 本地开发推荐使用 127.0.0.1。
BACKEND_HOST=127.0.0.1

# FastAPI 监听端口。
BACKEND_PORT=8000

# -----------------------------
# 本地数据目录
# -----------------------------
# 所有运行数据的根目录。建议保持相对路径，便于项目迁移。
DATA_DIR=data

# 原始上传文件目录。文件实际保存为 document_id + 原扩展名，不使用原始文件名作为路径。
FILES_DIR=data/files

# 解析后的纯文本目录。公开 API 不直接返回 parsed text 正文。
PARSED_DIR=data/parsed

# SQLite 数据库文件路径。
SQLITE_DB_PATH=data/sqlite/workmemory.db

# Chroma 本地向量库持久化目录。
CHROMA_PERSIST_DIR=data/vector_db

# SQLAlchemy 数据库 URL。留空时后端会根据 SQLITE_DB_PATH 自动生成。
# 当前本地优先 MVP 推荐使用 SQLite。
DATABASE_URL=sqlite:///data/sqlite/workmemory.db

# -----------------------------
# OpenAI-compatible API
# -----------------------------
# OpenAI 或兼容服务 API Key。示例文件中必须留空。
OPENAI_API_KEY=

# OpenAI-compatible Base URL。真实 OpenAI 默认是 https://api.openai.com/v1。
OPENAI_BASE_URL=https://api.openai.com/v1

# Chat/RAG/摘要使用的模型名。
OPENAI_MODEL=gpt-4o-mini

# LLM Provider。可选：openai、fake。
# fake 仅用于本地 smoke 和测试，不建议作为真实使用配置。
LLM_PROVIDER=openai

# LLM 请求超时时间，单位秒。
LLM_TIMEOUT_SECONDS=60

# -----------------------------
# Embedding 与 Chroma 索引
# -----------------------------
# Embedding 模型名。
EMBEDDING_MODEL=text-embedding-3-small

# Embedding Provider。可选：openai、fake。
# 如果使用 openai，必须配置 OPENAI_API_KEY。
# 如果只是本地功能测试，可改为 fake，并重启后端。
EMBEDDING_PROVIDER=openai

# 每批生成 embedding 的文本数量。
# 注意：百炼 DashScope text-embedding-v4 单次最多 10 条文本，使用百炼时请设置为 10。
EMBEDDING_BATCH_SIZE=64

# Embedding 请求超时时间，单位秒。
EMBEDDING_TIMEOUT_SECONDS=60

# Chroma collection 名称。同一 collection 不允许混用不同 embedding dimension。
CHROMA_COLLECTION_NAME=workmemory_chunks

# -----------------------------
# Retrieval / RAG
# -----------------------------
# 来源检索默认返回数量。
DEFAULT_RETRIEVAL_TOP_K=5

# 来源检索允许的最大返回数量。
MAX_RETRIEVAL_TOP_K=20

# RAG 默认使用的来源数量。
RAG_TOP_K=5

# RAG prompt 可注入的最大文档上下文字符数。
RAG_MAX_CONTEXT_CHARS=12000

# RAG 返回 sources 时，每条来源 excerpt 的最大字符数。
RAG_SOURCE_EXCERPT_CHARS=500

# 是否在检索前用 LLM 将用户问题改写为更适合向量检索的查询。
# 默认关闭；开启后如果 LLM provider 未配置或改写失败，会自动回退原始 query。
RAG_QUERY_REWRITE_ENABLED=false

# query rewrite 输出的最大字符数。
RAG_QUERY_REWRITE_MAX_CHARS=500

# -----------------------------
# Memory 上下文
# -----------------------------
# 单条 memory 注入 Chat/RAG prompt 时的最大字符数。
# 截断只影响 prompt 和返回预览，不修改数据库内容。
MEMORY_CONTEXT_MAX_CHARS_PER_ITEM=1200

# 所有 memory 注入 Chat/RAG prompt 时的总字符上限。
MEMORY_CONTEXT_MAX_TOTAL_CHARS=5000

# -----------------------------
# Chat 上下文与 Conversation Summary
# -----------------------------
# Chat 继续对话时最多选取的最近消息数。
CHAT_CONTEXT_RECENT_MESSAGES=8

# Chat conversation context 的最大字符数。
CHAT_CONTEXT_MAX_CHARS=6000

# 手动生成摘要时最多读取的消息数。
CONVERSATION_SUMMARY_MAX_MESSAGES=80

# 手动生成摘要时 prompt 可使用的最大消息字符数。
CONVERSATION_SUMMARY_MAX_CHARS=12000

# 期望摘要长度，用于提示 LLM 控制摘要规模。
CONVERSATION_SUMMARY_TARGET_CHARS=1800

# 是否允许 Chat 请求后自动刷新摘要。
# 默认关闭，避免默认增加 LLM 成本和延迟。
AUTO_SUMMARY_ENABLED=false

# 已有摘要 stale 后，新增消息数达到该值才认为需要刷新。
AUTO_SUMMARY_MIN_NEW_MESSAGES=6

# 没有摘要时，总消息数达到该值才认为需要生成摘要。
AUTO_SUMMARY_MIN_TOTAL_MESSAGES=10

# 单次 Chat 请求后最多自动刷新摘要的次数。当前 MVP 建议保持 1。
AUTO_SUMMARY_MAX_PER_CHAT=1

# -----------------------------
# Pipeline Worker
# -----------------------------
# Pipeline worker 并发数。当前本地 MVP 建议保持 1，避免多个大文件同时解析/索引导致资源占用过高。
PIPELINE_WORKER_CONCURRENCY=1

# Pipeline worker 轮询 queued job 的间隔，单位秒。
PIPELINE_POLL_INTERVAL_SECONDS=1

# running job 的 lease 过期时间，单位秒。后端重启或 worker 异常后，过期任务会被恢复为 queued。
PIPELINE_LOCK_TIMEOUT_SECONDS=3600

# -----------------------------
# 上传限制
# -----------------------------
# 单个上传文件最大大小，单位 MB。
MAX_UPLOAD_SIZE_MB=50

# -----------------------------
# 文件解析限制
# -----------------------------
# 单个 parsed text 最大字符数，超过会截断并标记 truncated。
MAX_PARSE_CHARS=2000000

# PDF 最大解析页数。
MAX_PARSE_PAGES=200

# CSV/Excel 每个 sheet 最大读取行数。
MAX_PARSE_ROWS=10000

# Excel 最大读取 sheet 数。
MAX_PARSE_SHEETS=20

# -----------------------------
# Chunking 限制
# -----------------------------
# 单个 chunk 最大字符数，必须大于 0。
MAX_CHUNK_CHARS=1200

# 相邻 chunk 重叠字符数，必须 >= 0 且小于 MAX_CHUNK_CHARS。
CHUNK_OVERLAP_CHARS=150

# 单个文档最多保留的 chunks 数量，超出会截断并标记 truncated。
MAX_CHUNKS_PER_DOCUMENT=5000
